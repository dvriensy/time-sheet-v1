rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions (Pillar 3)
    function isValidId(id) {
      return id is string && id.size() >= 2 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Users Collection ---
    match /users/{username} {
      allow read: if true;
      allow create, update: if isValidId(username) && isValidUser(incoming());
      allow delete: if isValidId(username);
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 &&
             data.firstName is string && data.firstName.size() >= 0 &&
             data.lastName is string && data.lastName.size() >= 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             (!('password' in data) || (data.password is string && data.password.size() >= 0)) &&
             (data.role == 'employee' || data.role == 'manager');
    }

    // --- Timesheets Collection ---
    match /timesheets/{timesheetId} {
      allow read: if true;
      allow create, update: if isValidId(timesheetId) && isValidTimesheet(incoming());
      allow delete: if isValidId(timesheetId);
    }

    function isValidTimesheet(data) {
      return data.id is string && data.id.size() > 0 &&
             (!('username' in data) || data.username is string) &&
             data.date is string && data.date.size() == 10 &&
             data.startTime is string && data.startTime.size() == 5 &&
             data.endTime is string && data.endTime.size() == 5 &&
             (!('breakMinutes' in data) || (data.breakMinutes is float || data.breakMinutes is int)) &&
             (!('project' in data) || data.project is string) &&
             (!('locationName' in data) || data.locationName is string) &&
             (data.totalHours is float || data.totalHours is int);
    }

    // --- Active Sessions Collection ---
    match /activeSessions/{username} {
      allow read: if true;
      allow create, update: if isValidId(username) && isValidActiveSession(incoming());
      allow delete: if isValidId(username);
    }

    function isValidActiveSession(data) {
      return data.username is string && data.username.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.isClockedIn is bool &&
             data.isOnBreak is bool &&
             data.startTime is string &&
             (!('project' in data) || data.project is string) &&
             (!('location' in data) || data.location is string) &&
             (!('notes' in data) || data.notes is string) &&
             data.lastActiveTimestamp is string;
    }

    // --- Time-Off Requests Collection ---
    match /timeOffRequests/{requestId} {
      allow read: if true;
      allow create, update: if isValidId(requestId) && isValidTimeOffRequest(incoming());
      allow delete: if isValidId(requestId);
    }

    function isValidTimeOffRequest(data) {
      return data.id is string && data.id.size() > 0 &&
             data.username is string && data.username.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.startDate is string && data.startDate.size() == 10 &&
             data.endDate is string && data.endDate.size() == 10 &&
             (!('reason' in data) || data.reason is string) &&
             (data.status == 'pending' || data.status == 'approved' || data.status == 'denied') &&
             data.createdAt is string &&
             data.acknowledgedByRequester is bool;
    }

    // --- Future Shifts Collection ---
    match /futureShifts/{shiftId} {
      allow read: if true;
      allow create, update: if isValidId(shiftId) && isValidFutureShift(incoming());
      allow delete: if isValidId(shiftId);
    }

    function isValidFutureShift(data) {
      return data.id is string && data.id.size() > 0 &&
             data.username is string && data.username.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.date is string && data.date.size() == 10 &&
             data.startTime is string && data.startTime.size() == 5 &&
             data.endTime is string && data.endTime.size() == 5 &&
             (!('project' in data) || data.project is string) &&
             (!('notes' in data) || data.notes is string) &&
             data.createdAt is string;
    }

    // --- Submitted Timesheets Collection ---
    match /submittedTimesheets/{submissionId} {
      allow read: if true;
      allow create, update: if isValidId(submissionId) && isValidSubmittedTimesheet(incoming());
      allow delete: if isValidId(submissionId);
    }

    function isValidSubmittedTimesheet(data) {
      return data.id is string && data.id.size() > 0 &&
             (!('username' in data) || data.username is string) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.startDate is string && data.startDate.size() == 10 &&
             data.endDate is string && data.endDate.size() == 10 &&
             (data.totalHours is float || data.totalHours is int) &&
             (data.regularHours is float || data.regularHours is int) &&
             (data.overtimeHours is float || data.overtimeHours is int) &&
             data.submittedAt is string &&
             (data.status == 'submitted' || data.status == 'approved' || data.status == 'rejected') &&
             data.entries is list;
    }

  }
}
